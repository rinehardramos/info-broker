# info-broker environment configuration
# Copy to .env and fill in values.

# REST API auth — required. Clients must send this in X-API-Key header.
INFO_BROKER_API_KEY=replace-with-a-strong-random-string

# PlayGen callback base URL (info-broker POSTs audio-sourcing results here)
PLAYGEN_INTERNAL_URL=https://api.playgen.site

# Postgres
POSTGRES_DB=info_broker
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6335

# Local LLM (LM Studio / Ollama compatible)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
CHAT_MODEL_NAME=local-model
EMBEDDING_MODEL_NAME=local-embed

# Apify dataset URL for /ingest
APIFY_DATASET_URL=https://api.apify.com/v2/datasets/<id>/items?format=json

# S3-compatible storage (Cloudflare R2) — used by POST /v1/playlists/source-audio.
# Bucket: ownradio  |  Endpoint: Cloudflare R2 account endpoint
S3_BUCKET=ownradio
S3_ENDPOINT=https://fa958caa19c273f07b49c49a09d76a60.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=replace-with-s3-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-s3-secret-access-key
