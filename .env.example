# info-broker environment configuration
# Copy to .env and fill in values.

# REST API auth — required. Clients must send this in X-API-Key header.
INFO_BROKER_API_KEY=replace-with-a-strong-random-string

# Postgres
POSTGRES_DB=info_broker
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6335

# Local LLM (LM Studio / Ollama compatible)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
CHAT_MODEL_NAME=local-model
EMBEDDING_MODEL_NAME=local-embed

# Apify dataset URL for /ingest
APIFY_DATASET_URL=https://api.apify.com/v2/datasets/<id>/items?format=json
